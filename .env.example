# ── Camera ──────────────────────────────────────────────────────────────────────
# Choose ONE of the following:

# RTSP stream (IP camera — Hikvision format)
CAMERA_RTSP_URL=rtsp://admin:PASSWORD@192.168.1.100:554/Streaming/Channels/101

# USB or built-in camera (index 0 = first camera)
# CAMERA_INDEX=0

# HTTP MJPEG stream
# CAMERA_HTTP_URL=http://192.168.1.100:8080/video

# Test mode — use a local video file instead of a real camera
# TEST_VIDEO_PATH=/data/sample_conveyor.mp4


# ── Detection tuning ─────────────────────────────────────────────────────────
# Adjust after observing behavior via the debug feed (localhost:8080)

DETECTION_LINE_Y_PERCENT=50       # 0-100, vertical position of counting tripwire
MIN_CONTOUR_AREA=2000             # pixels² — minimum moving region to count as board
COUNT_COOLDOWN_MS=800             # ms between counts on same zone (prevents double-count)
PRODUCTION_DIRECTION=left_to_right # or right_to_left


# ── Speed calibration ────────────────────────────────────────────────────────
# Measure the real-world length of conveyor visible in camera frame

CONVEYOR_VISIBLE_FEET=8.0


# ── Downtime detection ───────────────────────────────────────────────────────

DOWNTIME_THRESHOLD_SECONDS=45    # seconds of no boards before declaring downtime
DEBUG_OVERLAY=false              # set true to annotate live feed at localhost:8080


# ── Production targets ───────────────────────────────────────────────────────

TARGET_PIECES_PER_HOUR=450


# ── Shift schedule (24h format) ──────────────────────────────────────────────

SHIFT_DAY_START=06:00
SHIFT_AFT_START=14:00
SHIFT_NIGHT_START=22:00


# ── Database ─────────────────────────────────────────────────────────────────
# CHANGE THIS in production

DB_PASSWORD=changeme_in_production


# ── Network ──────────────────────────────────────────────────────────────────
# Set to the host machine's LAN IP so the dashboard JS can reach the API
# (needed because VITE_API_URL is baked into the dashboard at build time)

HOST_IP=192.168.1.xxx
